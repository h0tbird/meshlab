{
	"$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.base.schema.json",
	"name": "meshlab",
	"build": {
		"dockerfile": "Dockerfile",
		"options": [
			"--tag", "ghcr.io/h0tbird/meshlab/devcontainer:latest",
			"--progress=plain",
			"--network=host" // Workaround for possible MTU-related Docker networking issues.
		]
	},
	"initializeCommand": {
		"lazy-load-ssh-keys": "ssh -T git@github.com || true",
		"create-istio-dir": "mkdir -p ${localWorkspaceFolder}/../istio",
		"create-k-swarm-dir": "mkdir -p ${localWorkspaceFolder}/../k-swarm"
	},
	"mounts": [
		// DooD: Docker Desktop's host-services proxy socket. More robust than
		// bind-mounting the host's /var/run/docker.sock, which requires the
		// "default Docker socket" option and can go stale across restarts.
		"type=bind,source=/run/host-services/docker.proxy.sock,target=/var/run/docker-host.sock",
		"type=bind,source=/run/host-services/ssh-auth.sock,target=/ssh-agent",
		"type=bind,source=${localEnv:HOME}/.kube/config,target=/root/.kube/config.host",
		"type=bind,source=${localWorkspaceFolder}/../istio,target=/workspaces/istio",
		"type=bind,source=${localWorkspaceFolder}/../k-swarm,target=/workspaces/k-swarm"
	],
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:3": {},
		"ghcr.io/devcontainers/features/sshd:1": {}
	},
	// Injected only into VS Code shells and lifecycle scripts, not into the image
	// or PID 1 (the docker-in-docker entrypoint):
	//   - GITHUB_TOKEN/GITHUB_USER: keep the token out of container metadata
	//     while still available to `gh`.
	//   - DOCKER_HOST: default plain `docker` to DooD (host Docker Desktop).
	//     Kept out of containerEnv so it doesn't break the DinD entrypoint's
	//     `docker info` readiness probe. The `dind`/`dood` helpers use explicit
	//     -H and are unaffected.
	"remoteEnv": {
		"LOCAL_WORKSPACE_FOLDER": "${localWorkspaceFolder}",
		"GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
		"GITHUB_USER": "${localEnv:GITHUB_USER}",
		"DOCKER_HOST": "unix:///var/run/docker-host.sock"
	},
	// Runs as root with a privileged, host-networked container. Required for the
	// in-container kind clusters and DinD; this trades isolation for capability
	// and is safe only because the container is a local, single-user dev sandbox.
	"remoteUser": "root",
	"runArgs": [
		"--name", "meshlab",
		"--network", "host",
		"--privileged"
	],
	"forwardPorts": [8080, 8081, 8082, 8083, 8084, 8085, 9091, 9092],
	"portsAttributes": {
		"8080": {
			"label": "argocd",
			"onAutoForward": "notify",
			"protocol": "http"
		},
		"8081": {
			"label": "argowf",
			"onAutoForward": "notify",
			"protocol": "http"
		},
		"8082": {
			"label": "vault",
			"onAutoForward": "notify",
			"protocol": "http"
		},
		"8083": {
			"label": "prometheus",
			"onAutoForward": "notify",
			"protocol": "http"
		},
		"8084": {
			"label": "grafana",
			"onAutoForward": "notify",
			"protocol": "http"
		},
		"8085": {
			"label": "kiali",
			"onAutoForward": "notify",
			"protocol": "http"
		},
		"9091": {
			"label": "tilt-pasta-1",
			"onAutoForward": "notify",
			"protocol": "http"
		},
		"9092": {
			"label": "tilt-pasta-2",
			"onAutoForward": "notify",
			"protocol": "http"
		}
	},
	"otherPortsAttributes": {
		"onAutoForward" : "ignore"
	},
	"customizations": {
		"vscode": {
			"settings": {
				"remote.autoForwardPorts":false,
				"window.openFilesInNewWindow": "off"
			},
			"extensions": [
				"github.copilot",
				"github.vscode-pull-request-github",
				"golang.go",
				"ms-azuretools.vscode-docker",
				"timonwong.shellcheck",
				"shardulm94.trailing-spaces",
				"tilt-dev.tiltfile"
			]
		}
	},
	"hostRequirements": {
		"cpus": 8,
		"memory": "15gb"
	},
	"postCreateCommand": {
		// Backup config.json for restoring after DinD.
		"backup-docker-config": "cp ~/.docker/config.json ~/.docker/config.json.bkp"
	},
	"postStartCommand": {
		// Clone repos if missing. Override defaults with MESHLAB_ISTIO_REPO / MESHLAB_KSWARM_REPO=<owner>/<repo>.
		// When a fork is used, an 'upstream' remote pointing at the canonical repo is added automatically.
		"clone-istio": ".devcontainer/clone-repo.sh istio/istio ${localEnv:MESHLAB_ISTIO_REPO:istio/istio} /workspaces/istio",
		"clone-k-swarm": ".devcontainer/clone-repo.sh h0tbird/k-swarm ${localEnv:MESHLAB_KSWARM_REPO:h0tbird/k-swarm} /workspaces/k-swarm"
	}
}
