#!/usr/bin/env bash
#
# check-docker-dind — verify the DinD backend (inner Docker Engine).
#
# Probes /var/run/docker.sock directly with a hard timeout so it never hangs
# while the inner daemon is still starting. Prints "OK: ..." on success,
# "FAIL: ..." and a non-zero exit otherwise.

set -uo pipefail

sock=/var/run/docker.sock
name='DinD (inner Docker Engine)'

if [[ ! -S "${sock}" ]]; then
  echo "FAIL: ${name} — socket ${sock} is missing (inner daemon not started yet)"
  exit 1
fi

if ver=$(curl -fsS --unix-socket "${sock}" --connect-timeout 2 --max-time 5 \
  http://localhost/version 2>/dev/null); then
  platform=$(jq -r '.Platform.Name // "unknown"' <<<"${ver}")
  api=$(jq -r '.ApiVersion // "?"' <<<"${ver}")
  echo "OK: ${name} reachable — ${platform} (API ${api})"
else
  echo "FAIL: ${name} — ${sock} did not respond within 5s (inner dockerd still starting or unhealthy)"
  exit 1
fi
